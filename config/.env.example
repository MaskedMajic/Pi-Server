# Copy this file to config/.env and fill in real values.
# NEVER commit config/.env . Only this .example file is tracked.

# ---- Discord ----
DISCORD_TOKEN=your-discord-bot-token
WATCH_GUILD_ID=000000000000000000
WATCH_CHANNEL_ID=000000000000000000
OWNER_USER_ID=000000000000000000
APPROVED_AUTHOR_IDS=000000000000000000,111111111111111111

# ---- Relay ----
# Leave RELAY_HOST as 0.0.0.0 — the bot on this same Pi needs loopback
# access, and the extension needs the Tailscale interface. Pinning this
# to one specific IP breaks the other.
RELAY_HOST=0.0.0.0
RELAY_PORT=8000
RELAY_WS_URL=ws://127.0.0.1:8000/ws/bot

# One token shared by bot <-> relay (same process pair, one secret).
RELAY_BOT_TOKEN=generate-a-long-random-string-1
# A different token, handed out to each extension user you onboard.
RELAY_EXTENSION_TOKEN=generate-a-long-random-string-2

# ---- Behaviour ----
PRODUCT_COOLDOWN_SECONDS=90
EVENT_MAX_AGE_SECONDS=30
